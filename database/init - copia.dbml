Project elysiumDatabase {
  database_type: "MariaDB"
}

Table user {
  user_id bigint [pk, increment]
  first_name varchar(100) [not null]
  surnames varchar(200) [not null]
  username varchar(50) [not null, unique]
  password varchar(255) [not null]
  email varchar(100) [not null, unique]
  profile_img varchar(200)
  is_active boolean [not null, default: false]
  temporalTokenActivaction varchar(255)
}

Table user_activity {
  activity_id bigint [pk, increment]
  user_id bigint [not null]
  action_type enum('create', 'update', 'delete') [not null]
  action_details text [not null]
  create_at timestamp [default: `current_timestamp`]
}

Table user_enterprise {
  user_id bigint [pk]
  enterprise_name varchar(100)
  enterprise_phone varchar(15)
}

Table follow {
  follower_id bigint
  followed_id bigint

  Indexes {
    (follower_id, followed_id) [pk]
  }
}

Table post {
  post_id bigint [pk, increment]
  user_id bigint [not null]
  title varchar(200)
  description_post varchar(500)
  created_at timestamp [default: `current_timestamp`]
}

Table like {
  user_id bigint
  post_id bigint

  Indexes {
    (user_id, post_id) [pk]
  }
}

Table comment {
  comment_id bigint [pk, increment]
  user_id bigint [not null]
  message text [not null]
  post_id bigint [not null]
  created_at timestamp [default: `current_timestamp`]
}

Table chat {
  chat_id bigint [pk, increment]
  user_1 bigint [not null]
  user_2 bigint [not null]

  Indexes {
    (user_1, user_2) [unique]
  }
}

Table message {
  message_id bigint [pk, increment]
  chat_id bigint [not null]
  content text [not null]
  sennt_at timestamp [default: `current_timestamp`]
  is_read boolean
  user_send_id bigint [not null]
}

Table job {
  job_id bigint [pk, increment]
  user_id bigint [not null]
  title varchar(200) [not null]
  description text [not null]
  location varchar(100) [not null]
  salary varchar(50) [not null]
  created_at timestamp [default: `current_timestamp`]
  is_active boolean [not null]
}

Table application {
  application_job bigint [pk, increment]
  job_id bigint [not null]
  user_id bigint [not null]
  message text [not null]
  applied_at timestamp [not null]
}

Ref: user_activity.user_id > user.user_id
Ref: user_enterprise.user_id > user.user_id
Ref: follow.follower_id > user.user_id
Ref: follow.followed_id > user.user_id
Ref: post.user_id > user.user_id
Ref: like.user_id > user.user_id
Ref: like.post_id > post.post_id
Ref: comment.user_id > user.user_id
Ref: comment.post_id > post.post_id
Ref: chat.user_1 > user.user_id
Ref: chat.user_2 > user.user_id
Ref: message.chat_id > chat.chat_id
Ref: message.user_send_id > user.user_id
Ref: job.user_id > user.user_id
Ref: application.job_id > job.job_id
Ref: application.user_id > user.user_id